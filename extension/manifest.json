{
  "manifest_version": 3,
  "name": "YouTube Intelligence AI",
  "version": "1.0",
  "description": "Analyze Sentiment, Emotions & Summarize YouTube Videos using AI.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://ytana.onrender.com/*",
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}